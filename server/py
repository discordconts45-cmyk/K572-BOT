    if role:
        await member.add_roles(role)

    for ch in member.guild.text_channels:
        if ch.name == "welcome":
            await ch.send(f"Bine ai venit {member.mention}")
            break

# ===== SPAM DETECT =====
spam = {}

@bot.event
async def on_message(msg):
    if msg.author.bot: return

    t = datetime.datetime.now().timestamp()
    spam.setdefault(msg.author.id, []).append(t)
    spam[msg.author.id] = [x for x in spam[msg.author.id] if t-x < 5]

    if len(spam[msg.author.id]) > 7:
        await msg.delete()
        return await msg.channel.send("spam")

    await bot.process_commands(msg)

