# ===== SPAM SYSTEM =====
spam_tasks = {}

@bot.command()
async def start(ctx, member:discord.Member):
    if ctx.guild.id in spam_tasks:
        return await ctx.send("deja merge")

    insults = ["esti slab","npc","zero skill","fail","trash"]

    async def spam_loop():
        while True:
            await ctx.send(f"{member.mention} {random.choice(insults)}")
            await asyncio.sleep(2)

    spam_tasks[ctx.guild.id] = bot.loop.create_task(spam_loop())
    await ctx.send("spam pornit")

@bot.command()
async def stop(ctx):
    task = spam_tasks.get(ctx.guild.id)
    if task:
        task.cancel()
        del spam_tasks[ctx.guild.id]
        await ctx.send("spam oprit")

# ===== MOD =====
@bot.command()
async def ban(ctx, member:discord.Member):
